// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// ENUMS
// =====================

enum CivilState {
  SINGLE       @map("SINGLE")
  MARRIED      @map("MARRIED")
  DIVORCED     @map("DIVORCED")
  WIDOWED      @map("WIDOWED")
  SEPARATED    @map("SEPARATED")
  STABLE_UNION @map("STABLE_UNION")
}

enum ProductType {
  CAR      @map("CAR")
  BOAT     @map("BOAT")
  AIRCRAFT @map("AIRCRAFT")
}

enum UserRole {
  CUSTOMER   @map("CUSTOMER")
  CONSULTANT @map("CONSULTANT")
  SPECIALIST @map("SPECIALIST")
  ADMIN      @map("ADMIN")
}

enum ProcessStatus {
  SCHEDULING    @map("SCHEDULING")
  NEGOTIATION   @map("NEGOTIATION")
  DOCUMENTATION @map("DOCUMENTATION")
  COMPLETED     @map("COMPLETED")
}

enum ContractStatus {
  PENDING  @map("PENDING")
  REJECTED @map("REJECTED")
  SIGNED   @map("SIGNED")
}

// =====================
// MODELS
// =====================

model User {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  surname       String
  email         String   @unique
  cpf           String   @unique @db.VarChar(11)
  rg            String   @unique @db.VarChar(10)
  role          UserRole
  password_hash String

  civil_state           CivilState?
  speciality            ProductType?
  identification_number String?      @unique @db.VarChar(50)

  address_id    String? @db.Uuid
  consultant_id String? @db.Uuid
  company_id    String? @db.Uuid

  address    Address? @relation(fields: [address_id], references: [id])
  consultant User?    @relation("ClientToConsultant", fields: [consultant_id], references: [id], onDelete: SetNull)
  clients    User[]   @relation("ClientToConsultant")
  company    Company? @relation(fields: [company_id], references: [id])

  created_at               DateTime            @default(now())
  updated_at               DateTime            @updatedAt
  cars                     Car[]
  boats                    Boat[]
  aircraft                 Aircraft[]
  processesAsClient        Process[]           @relation("process_as_client")
  processesAsSpecialist    Process[]           @relation("process_as_specialist")
  appointmentsAsClient     Appointment[]       @relation("appointment_as_client")
  appointmentsAsSpecialist Appointment[]       @relation("appointment_as_specialist")
  car_interests            Car_interest[]
  boat_interests           Boat_interest[]
  aircraft_interests       Aircraft_interest[]
  refreshTokens            RefreshToken[]
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  token      String   @unique
  user_id    String   @db.Uuid
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([user_id])
  @@index([token])
}

model Address {
  id           String @id @default(uuid()) @db.Uuid
  street       String
  number       String
  neighborhood String
  city         String
  state        String
  cep          String
  country      String

  users User[]
}

model Company {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  cnpj        String   @unique
  logo        String?
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  consultants User[]
}

model Car {
  id             Int      @id @default(autoincrement())
  specialist_id  String?  @db.Uuid
  marca          String
  modelo         String
  valor          Decimal
  estado         String
  ano            Int
  descricao      String?
  cor            String?
  km             Int?
  cambio         String?
  combustivel    String?
  tipo_categoria String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  specialist User?       @relation(fields: [specialist_id], references: [id])
  images     Car_image[]
  processes  Process[]
}

model Boat {
  id                 Int      @id @default(autoincrement())
  specialist_id      String?  @db.Uuid
  marca              String
  modelo             String
  valor              Decimal
  ano                Int
  fabricante         String?
  tamanho            String?
  estilo             String?
  combustivel        String?
  motor              String?
  ano_motor          Int?
  descricao_completa String?
  acessorios         String?
  estado             String
  tipo_embarcacao    String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  specialist User?        @relation(fields: [specialist_id], references: [id])
  images     Boat_image[]
  processes  Process[]
}

model Aircraft {
  id            Int      @id @default(autoincrement())
  specialist_id String?  @db.Uuid
  categoria     String?
  ano           Int
  marca         String
  modelo        String
  assentos      Int?
  estado        String
  descricao     String?
  valor         Decimal
  tipo_aeronave String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  specialist User?            @relation(fields: [specialist_id], references: [id])
  images     Aircraft_image[]
  processes  Process[]
}

model Car_image {
  id           Int      @id @default(autoincrement())
  product_type String
  image_url    String
  is_primary   Boolean  @default(false)
  created_at   DateTime @default(now())

  // relation to specific car (nullable to avoid breaking existing data)
  car_id Int?
  car    Car? @relation(fields: [car_id], references: [id])
}

model Boat_image {
  id           Int      @id @default(autoincrement())
  product_type String
  image_url    String
  is_primary   Boolean  @default(false)
  created_at   DateTime @default(now())

  boat_id Int?
  boat    Boat? @relation(fields: [boat_id], references: [id])
}

model Aircraft_image {
  id           Int      @id @default(autoincrement())
  product_type String
  image_url    String
  is_primary   Boolean  @default(false)
  created_at   DateTime @default(now())

  aircraft_id Int?
  aircraft    Aircraft? @relation(fields: [aircraft_id], references: [id])
}

model Process {
  id                 String        @id @default(uuid()) @db.Uuid
  client_id          String       @db.Uuid
  specialist_id      String       @db.Uuid
  car_id             Int?
  aircraft_id        Int?
  boat_id            Int?
  active_contract_id String?       @unique @db.Uuid
  product_type       ProductType
  status             ProcessStatus @default(SCHEDULING)
  notes              String?
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt

  car     Car?      @relation(fields: [car_id], references: [id])
  boat    Boat?     @relation(fields: [boat_id], references: [id])
  aicraft Aircraft? @relation(fields: [aircraft_id], references: [id])

  client     User @relation("process_as_client", fields: [client_id], references: [id], map: "fk_process_as_client")
  specialist User @relation("process_as_specialist", fields: [specialist_id], references: [id], map: "fk_process_as_specialist")

  active_contract Contract? @relation("process_active_contract", fields: [active_contract_id], references: [id])

  contracts Contract[] @relation("process_contracts")
}

model Contract {
  id                String         @id @default(uuid()) @db.Uuid
  process_id        String         @db.Uuid
  zapsign_token     String         @unique
  status            ContractStatus @default(PENDING)
  original_pdf_url  String
  signed_pdf_url    String?
  signer_link       String
  rejected_reason   String?
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  active_of_process Process?       @relation("process_active_contract")
  process           Process        @relation("process_contracts", fields: [process_id], references: [id])

  @@index([process_id])
}

model Appointment {
  id            Int         @id @default(autoincrement())
  client_id     String?     @db.Uuid
  specialist_id String?     @db.Uuid
  product_type  ProductType
  date          DateTime
  time          DateTime
  status        String      @default("scheduled")
  notes         String?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  client     User? @relation("appointment_as_client", fields: [client_id], references: [id], map: "fk_appointment_as_client")
  specialist User? @relation("appointment_as_specialist", fields: [specialist_id], references: [id], map: "fk_appointment_as_specialist")
}

model Car_interest {
  id                      Int      @id @default(autoincrement())
  client_id               String?  @db.Uuid
  uso_principal           String?
  preferencia_foco        String?
  faixa_valor             String?
  status                  String?
  marca_preferida         String?
  modelo_preferido        String?
  perfil_veiculo          String?
  blindagem               Boolean?
  carroceria              String?
  fator_importante        String?
  recursos_indispensaveis String?
  estilo_viagem           String?
  mensagem_imagem         String?
  prazo_aquisicao         String?
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  client User? @relation(fields: [client_id], references: [id])
}

model Boat_interest {
  id                      Int      @id @default(autoincrement())
  client_id               String?  @db.Uuid
  uso_principal           String?
  preferencia_foco        String?
  faixa_valor             String?
  status                  String?
  marca_preferida         String?
  modelo_preferido        String?
  tipo_embarcacao         String?
  tamanho_embarcacao      String?
  motor                   String?
  capacidade_pessoas      String?
  cabine_pernoite         String?
  experiencia_navegacao   String?
  operacao_embarcacao     String?
  marina_preferencia      String?
  recursos_indispensaveis String?
  prazo_aquisicao         String?
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  client User? @relation(fields: [client_id], references: [id])
}

model Aircraft_interest {
  id                      Int      @id @default(autoincrement())
  client_id               String?  @db.Uuid
  uso_principal           String?
  preferencia_foco        String?
  faixa_valor             String?
  status                  String?
  marca_preferida         String?
  modelo_preferido        String?
  tipo_aeronave           String?
  alcance_autonomia       String?
  capacidade_passageiros  String?
  experiencia_voo         String?
  operacao_aeronave       String?
  hangar_preferencia      String?
  configuracao_cabine     String?
  recursos_indispensaveis String?
  prazo_aquisicao         String?
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  client User? @relation(fields: [client_id], references: [id])
}

// =====================
// ENUMS 
// =====================

enum Especialidade {
  CARROS    @map("carros")
  BARCOS    @map("barcos")
  AERONAVES @map("aeronaves")
}

// ---------- Produtos (carros, barcos, aeronaves) ----------
enum EstadoProduto {
  NOVO     @map("novo")
  SEMINOVO @map("seminovo")
  COLECAO  @map("colecao")
}

enum TipoCategoriaCarro {
  SUV         @map("SUV")
  SEDAN       @map("sedan")
  COUPE       @map("coupe")
  CONVERSIVEL @map("conversivel")
  ESPORTIVO   @map("esportivo")
  SUPERCARRO  @map("supercarro")
}

enum TipoEmbarcacaoProduto {
  IATE     @map("iate")
  LANCHA   @map("lancha")
  CATAMARA @map("catamara")
  VELEIRO  @map("veleiro")
  JET_BOAT @map("jet_boat")
  OUTRO    @map("outro")
}

enum TipoAeronaveProduto {
  VLJ              @map("VLJ")
  EXECUTIVO_MEDIO  @map("executivo_medio")
  INTERCONTINENTAL @map("intercontinental")
  TURBOHELICE      @map("turbohelice")
  HELICOPTERO      @map("helicoptero")
}

// ---------- Processos ----------
enum TipoProdutoProcesso {
  CAR      @map("car")
  BOAT     @map("boat")
  AIRCRAFT @map("aircraft")
}

// ---------- Agendamentos ----------
enum TipoProdutoAgendamento {
  CAR      @map("car")
  BOAT     @map("boat")
  AIRCRAFT @map("aircraft")
}

enum StatusAgendamento {
  SCHEDULED @map("scheduled")
  COMPLETED @map("completed")
  CANCELLED @map("cancelled")
}

// ---------- Interesses de Barcos ----------
enum UsoPrincipalBoatInterest {
  LAZER                @map("lazer")
  CRUZEIROS            @map("cruzeiros")
  PESCA                @map("pesca")
  EVENTOS              @map("eventos")
  COLECAO_INVESTIMENTO @map("colecao_investimento")
}

enum PreferenciaFocoBoatInterest {
  CONFORTO    @map("conforto")
  PERFORMANCE @map("performance")
  EQUILIBRIO  @map("equilibrio")
}

enum FaixaValorBoatInterest {
  ATE_500K   @map("ate_500k")
  DE_500K_1M @map("500k_1M")
  ACIMA_1M   @map("acima_1M")
}

enum StatusBoatInterest {
  NOVA             @map("nova")
  SEMINOVA         @map("seminova")
  COLECAO_RARIDADE @map("colecao_raridade")
}

enum TipoEmbarcacaoBoatInterest {
  IATE     @map("iate")
  LANCHA   @map("lancha")
  CATAMARA @map("catamara")
  VELEIRO  @map("veleiro")
  JET_BOAT @map("jet_boat")
  OUTRO    @map("outro")
}

enum TamanhoEmbarcacao {
  ATE_30_PES   @map("ate_30_pes")
  DE_30_50_PES @map("30_50_pes")
  ACIMA_50_PES @map("acima_50_pes")
}

enum MotorBoatInterest {
  DIESEL           @map("diesel")
  GASOLINA         @map("gasolina")
  ELETRICO_HIBRIDO @map("eletrico_hibrido")
}

enum CapacidadePessoasBoat {
  DE_1_4 @map("1_4")
  DE_5_8 @map("5_8")
  MAIS_8 @map("mais_8")
}

enum CabinePernoiteBoat {
  DAY_BOAT  @map("day_boat")
  UMA_DUAS  @map("1_2_cabines")
  MAIS_DUAS @map("mais_2_cabines")
}

enum ExperienciaNavegacao {
  NENHUMA       @map("nenhuma")
  BASICA        @map("basica")
  MEDIO_PORTE   @map("medio_porte")
  IATES_GRANDES @map("iates_grandes")
}

enum OperacaoEmbarcacao {
  PESSOAL     @map("pessoal")
  COM_AUXILIO @map("com_auxilio")
  APENAS_CREW @map("apenas_crew_capitao")
}

enum MarinaPreferencia {
  POSSUI            @map("possui")
  PRECISA_INDICACAO @map("precisa_indicacao")
  NAO_PRIORIDADE    @map("nao_prioridade")
}

enum PrazoAquisicaoBoat {
  IMEDIATO @map("imediato")
  CURTO    @map("curto")
  MEDIO    @map("medio")
  LONGO    @map("longo")
}

// ---------- Interesses de Aeronaves ----------
enum UsoPrincipalAircraftInterest {
  CORPORATIVO          @map("corporativo")
  LAZER                @map("lazer")
  TURISMO              @map("turismo")
  TRANSPORTE_FAMILIA   @map("transporte_familia")
  COLECAO_INVESTIMENTO @map("colecao_investimento")
}

enum PreferenciaFocoAircraft {
  CONFORTO_LUXO @map("conforto_luxo")
  PERFORMANCE   @map("performance")
  EQUILIBRIO    @map("equilibrio")
}

enum FaixaValorAircraft {
  ATE_5M    @map("ate_5M")
  DE_5_20M  @map("5_20M")
  ACIMA_20M @map("acima_20M")
}

enum StatusAircraft {
  NOVA             @map("nova")
  SEMINOVA         @map("seminova")
  COLECAO_RARIDADE @map("colecao_raridade")
}

enum TipoAeronaveAircraft {
  VLJ              @map("VLJ")
  EXECUTIVO        @map("executivo")
  INTERCONTINENTAL @map("intercontinental")
  TURBOHELICE      @map("turbohelice")
  HELICOPTERO      @map("helicoptero")
  OUTRO            @map("outro")
}

enum AlcanceAutonomia {
  CURTA @map("curta")
  MEDIA @map("media")
  LONGA @map("longa")
}

enum CapacidadePassageiros {
  ATE_4  @map("ate_4")
  DE_5_8 @map("5_8")
  MAIS_8 @map("mais_8")
}

enum ExperienciaVoo {
  NENHUMA                   @map("nenhuma")
  AERONAVES_LEVES           @map("aeronaves_leves")
  EXECUTIVOS_TURBOHELICES   @map("executivos_turbohelices")
  GRANDES_INTERCONTINENTAIS @map("grandes_intercontinentais")
}

enum OperacaoAeronave {
  PILOTAR_PESSOALMENTE @map("pilotar_pessoalmente")
  COM_AUXILIO          @map("com_auxilio")
  APENAS_CREW_PILOTO   @map("apenas_crew_piloto")
}

enum HangarPreferencia {
  POSSUI            @map("possui")
  PRECISA_INDICACAO @map("precisa_indicacao")
  NAO_PRIORIDADE    @map("nao_prioridade")
}

enum ConfiguracaoCabine {
  EXECUTIVA           @map("executiva")
  PASSAGEIROS_FAMILIA @map("passageiros_familia")
  OUTRA               @map("outra")
}

enum PrazoAquisicaoAircraft {
  IMEDIATO @map("imediato")
  CURTO    @map("curto")
  MEDIO    @map("medio")
  LONGO    @map("longo")
}
