// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// MODELS
// =====================

model companies {
  id          Int           @id @default(autoincrement())
  name        String
  cnpj        String        @unique
  logo        String?
  description String?
  created_at  DateTime      @default(now())
  updated_at  DateTime      @default(now())

  consultants consultants[]
}

model consultants {
  id                    Int       @id @default(autoincrement())
  company_id            Int?
  name                  String
  identification_number String
  rg                    String
  cpf                   String    @unique
  cargo                 String?
  email                 String    @unique
  password_hash         String
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now())

  company companies? @relation(fields: [company_id], references: [id])
  clients clients[] // relação inversa: um consultor pode ter vários clientes
}

model clients {
  id            Int              @id @default(autoincrement())
  consultant_id Int?
  name          String
  rg            String
  cpf           String           @unique
  estado_civil  String?
  cep           String?
  endereco      String?
  email         String           @unique
  password_hash String
  created_at    DateTime         @default(now())
  updated_at    DateTime         @default(now())

  consultant          consultants?       @relation(fields: [consultant_id], references: [id])
  processes           processes[]
  appointments        appointments[]
  car_interests       car_interests[]
  boat_interests      boat_interests[]
  aircraft_interests  aircraft_interests[]
}

model specialists {
  id            Int      @id @default(autoincrement())
  name          String
  rg            String
  cpf           String   @unique
  email         String   @unique
  especialidade String
  password_hash String
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())

  cars          cars[]
  boats         boats[]
  aircraft      aircraft[]
  processes     processes[]
  appointments  appointments[]
}

model admins {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())
}

model cars {
  id             Int         @id @default(autoincrement())
  specialist_id  Int?
  marca          String
  modelo         String
  valor          Decimal
  estado         String
  ano            Int
  descricao      String?
  cor            String?
  km             Int?
  cambio         String?
  combustivel    String?
  tipo_categoria String?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @default(now())

  specialist specialists? @relation(fields: [specialist_id], references: [id])
}

model boats {
  id                 Int      @id @default(autoincrement())
  specialist_id      Int?
  marca              String
  modelo             String
  valor              Decimal
  ano                Int
  fabricante         String?
  tamanho            String?
  estilo             String?
  combustivel        String?
  motor              String?
  ano_motor          Int?
  descricao_completa String?
  acessorios         String?
  estado             String
  tipo_embarcacao    String?
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now())

  specialist specialists? @relation(fields: [specialist_id], references: [id])
}

model aircraft {
  id            Int      @id @default(autoincrement())
  specialist_id Int?
  categoria     String?
  ano           Int
  marca         String
  modelo        String
  assentos      Int?
  estado        String
  descricao     String?
  valor         Decimal
  tipo_aeronave String?
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())

  specialist specialists? @relation(fields: [specialist_id], references: [id])
}

model car_images {
  id           Int     @id @default(autoincrement())
  product_type String
  image_url    String
  is_primary   Boolean  @default(false)
  created_at   DateTime @default(now())
}

model boat_images {
  id           Int     @id @default(autoincrement())
  product_type String
  image_url    String
  is_primary   Boolean  @default(false)
  created_at   DateTime @default(now())
}

model aircraft_images {
  id           Int     @id @default(autoincrement())
  product_type String
  image_url    String
  is_primary   Boolean  @default(false)
  created_at   DateTime @default(now())
}

model processes {
  id            Int      @id @default(autoincrement())
  client_id     Int?
  specialist_id Int?
  product_type  String
  status        String   @default("agendamento")
  notes         String?
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())

  client     clients?     @relation(fields: [client_id], references: [id])
  specialist specialists? @relation(fields: [specialist_id], references: [id])
  documents  documents[]

}

model documents {
  id               Int      @id @default(autoincrement())
  process_id       Int?
  file_name        String
  file_path        String
  file_type        String?
  uploaded_by      Int
  uploaded_by_type String
  created_at       DateTime @default(now())

  process processes? @relation(fields: [process_id], references: [id])
}

model appointments {
  id            Int      @id @default(autoincrement())
  client_id     Int?
  specialist_id Int?
  product_type  String
  date          DateTime
  time          DateTime
  status        String   @default("scheduled")
  notes         String?
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())

  client     clients?     @relation(fields: [client_id], references: [id])
  specialist specialists? @relation(fields: [specialist_id], references: [id])
}

model car_interests {
  id                      Int      @id @default(autoincrement())
  client_id               Int?
  uso_principal           String?
  preferencia_foco        String?
  faixa_valor             String?
  status                  String?
  marca_preferida         String?
  modelo_preferido        String?
  perfil_veiculo          String?
  blindagem               Boolean?
  carroceria              String?
  fator_importante        String?
  recursos_indispensaveis String?
  estilo_viagem           String?
  mensagem_imagem         String?
  prazo_aquisicao         String?
  created_at              DateTime @default(now())
  updated_at              DateTime @default(now())

  client clients? @relation(fields: [client_id], references: [id])
}

model boat_interests {
  id                      Int      @id @default(autoincrement())
  client_id               Int?
  uso_principal           String?
  preferencia_foco        String?
  faixa_valor             String?
  status                  String?
  marca_preferida         String?
  modelo_preferido        String?
  tipo_embarcacao         String?
  tamanho_embarcacao      String?
  motor                   String?
  capacidade_pessoas      String?
  cabine_pernoite         String?
  experiencia_navegacao   String?
  operacao_embarcacao     String?
  marina_preferencia      String?
  recursos_indispensaveis String?
  prazo_aquisicao         String?
  created_at              DateTime @default(now())
  updated_at              DateTime @default(now())

  client clients? @relation(fields: [client_id], references: [id])
}

model aircraft_interests {
  id                      Int      @id @default(autoincrement())
  client_id               Int?
  uso_principal           String?
  preferencia_foco        String?
  faixa_valor             String?
  status                  String?
  marca_preferida         String?
  modelo_preferido        String?
  tipo_aeronave           String?
  alcance_autonomia       String?
  capacidade_passageiros  String?
  experiencia_voo         String?
  operacao_aeronave       String?
  hangar_preferencia      String?
  configuracao_cabine     String?
  recursos_indispensaveis String?
  prazo_aquisicao         String?
  created_at              DateTime @default(now())
  updated_at              DateTime @default(now())

  client clients? @relation(fields: [client_id], references: [id])
}


// =====================
// ENUMS 
// =====================

enum Especialidade {
  CARROS     @map("carros")
  BARCOS     @map("barcos")
  AERONAVES  @map("aeronaves")
}

// ---------- Produtos (carros, barcos, aeronaves) ----------
enum EstadoProduto {
  NOVO       @map("novo")
  SEMINOVO   @map("seminovo")
  COLECAO    @map("colecao")
}

enum TipoCategoriaCarro {
  SUV          @map("SUV")
  SEDAN        @map("sedan")
  COUPE        @map("coupe")
  CONVERSIVEL  @map("conversivel")
  ESPORTIVO    @map("esportivo")
  SUPERCARRO   @map("supercarro")
}

enum TipoEmbarcacaoProduto {
  IATE       @map("iate")
  LANCHA     @map("lancha")
  CATAMARA   @map("catamara")
  VELEIRO    @map("veleiro")
  JET_BOAT   @map("jet_boat")
  OUTRO      @map("outro")
}

enum TipoAeronaveProduto {
  VLJ               @map("VLJ")
  EXECUTIVO_MEDIO   @map("executivo_medio")
  INTERCONTINENTAL  @map("intercontinental")
  TURBOHELICE       @map("turbohelice")
  HELICOPTERO       @map("helicoptero")
}

// ---------- Processos ----------
enum TipoProdutoProcesso {
  CAR        @map("car")
  BOAT       @map("boat")
  AIRCRAFT   @map("aircraft")
}

enum StatusProcesso {
  AGENDAMENTO   @map("agendamento")
  NEGOCIACAO    @map("negociacao")
  DOCUMENTACAO  @map("documentacao")
  CONCLUIDO     @map("concluido")
}

// ---------- Documentos ----------
enum UploadTypeDocumento {
  CLIENTE      @map("client")
  ESPECIALISTA @map("specialist")
}

// ---------- Agendamentos ----------
enum TipoProdutoAgendamento {
  CAR        @map("car")
  BOAT       @map("boat")
  AIRCRAFT   @map("aircraft")
}

enum StatusAgendamento {
  SCHEDULED  @map("scheduled")
  COMPLETED  @map("completed")
  CANCELLED  @map("cancelled")
}

// ---------- Interesses de Barcos ----------
enum UsoPrincipalBoatInterest {
  LAZER               @map("lazer")
  CRUZEIROS           @map("cruzeiros")
  PESCA               @map("pesca")
  EVENTOS             @map("eventos")
  COLECAO_INVESTIMENTO @map("colecao_investimento")
}

enum PreferenciaFocoBoatInterest {
  CONFORTO    @map("conforto")
  PERFORMANCE @map("performance")
  EQUILIBRIO  @map("equilibrio")
}

enum FaixaValorBoatInterest {
  ATE_500K    @map("ate_500k")
  DE_500K_1M  @map("500k_1M")
  ACIMA_1M    @map("acima_1M")
}

enum StatusBoatInterest {
  NOVA              @map("nova")
  SEMINOVA          @map("seminova")
  COLECAO_RARIDADE  @map("colecao_raridade")
}

enum TipoEmbarcacaoBoatInterest {
  IATE       @map("iate")
  LANCHA     @map("lancha")
  CATAMARA   @map("catamara")
  VELEIRO    @map("veleiro")
  JET_BOAT   @map("jet_boat")
  OUTRO      @map("outro")
}

enum TamanhoEmbarcacao {
  ATE_30_PES    @map("ate_30_pes")
  DE_30_50_PES  @map("30_50_pes")
  ACIMA_50_PES  @map("acima_50_pes")
}

enum MotorBoatInterest {
  DIESEL            @map("diesel")
  GASOLINA          @map("gasolina")
  ELETRICO_HIBRIDO  @map("eletrico_hibrido")
}

enum CapacidadePessoasBoat {
  DE_1_4      @map("1_4")
  DE_5_8      @map("5_8")
  MAIS_8      @map("mais_8")
}

enum CabinePernoiteBoat {
  DAY_BOAT        @map("day_boat")
  UMA_DUAS        @map("1_2_cabines")
  MAIS_DUAS       @map("mais_2_cabines")
}

enum ExperienciaNavegacao {
  NENHUMA        @map("nenhuma")
  BASICA         @map("basica")
  MEDIO_PORTE    @map("medio_porte")
  IATES_GRANDES  @map("iates_grandes")
}

enum OperacaoEmbarcacao {
  PESSOAL         @map("pessoal")
  COM_AUXILIO     @map("com_auxilio")
  APENAS_CREW     @map("apenas_crew_capitao")
}

enum MarinaPreferencia {
  POSSUI             @map("possui")
  PRECISA_INDICACAO  @map("precisa_indicacao")
  NAO_PRIORIDADE     @map("nao_prioridade")
}

enum PrazoAquisicaoBoat {
  IMEDIATO  @map("imediato")
  CURTO     @map("curto")
  MEDIO     @map("medio")
  LONGO     @map("longo")
}

// ---------- Interesses de Aeronaves ----------
enum UsoPrincipalAircraftInterest {
  CORPORATIVO           @map("corporativo")
  LAZER                 @map("lazer")
  TURISMO               @map("turismo")
  TRANSPORTE_FAMILIA    @map("transporte_familia")
  COLECAO_INVESTIMENTO  @map("colecao_investimento")
}

enum PreferenciaFocoAircraft {
  CONFORTO_LUXO @map("conforto_luxo")
  PERFORMANCE   @map("performance")
  EQUILIBRIO    @map("equilibrio")
}

enum FaixaValorAircraft {
  ATE_5M     @map("ate_5M")
  DE_5_20M   @map("5_20M")
  ACIMA_20M  @map("acima_20M")
}

enum StatusAircraft {
  NOVA              @map("nova")
  SEMINOVA          @map("seminova")
  COLECAO_RARIDADE  @map("colecao_raridade")
}

enum TipoAeronaveAircraft {
  VLJ               @map("VLJ")
  EXECUTIVO         @map("executivo")
  INTERCONTINENTAL  @map("intercontinental")
  TURBOHELICE       @map("turbohelice")
  HELICOPTERO       @map("helicoptero")
  OUTRO             @map("outro")
}

enum AlcanceAutonomia {
  CURTA  @map("curta")
  MEDIA  @map("media")
  LONGA  @map("longa")
}

enum CapacidadePassageiros {
  ATE_4   @map("ate_4")
  DE_5_8  @map("5_8")
  MAIS_8  @map("mais_8")
}

enum ExperienciaVoo {
  NENHUMA                   @map("nenhuma")
  AERONAVES_LEVES           @map("aeronaves_leves")
  EXECUTIVOS_TURBOHELICES   @map("executivos_turbohelices")
  GRANDES_INTERCONTINENTAIS @map("grandes_intercontinentais")
}

enum OperacaoAeronave {
  PILOTAR_PESSOALMENTE @map("pilotar_pessoalmente")
  COM_AUXILIO          @map("com_auxilio")
  APENAS_CREW_PILOTO   @map("apenas_crew_piloto")
}

enum HangarPreferencia {
  POSSUI             @map("possui")
  PRECISA_INDICACAO  @map("precisa_indicacao")
  NAO_PRIORIDADE     @map("nao_prioridade")
}

enum ConfiguracaoCabine {
  EXECUTIVA           @map("executiva")
  PASSAGEIROS_FAMILIA @map("passageiros_familia")
  OUTRA               @map("outra")
}

enum PrazoAquisicaoAircraft {
  IMEDIATO  @map("imediato")
  CURTO     @map("curto")
  MEDIO     @map("medio")
  LONGO     @map("longo")
}
