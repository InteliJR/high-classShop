  MEDIO    @map("medio")
  LONGO    @map("longo")
}

// ─────────────────────────────────────────────────────────────────────────────
// ▸ INTERESSES (Preferências de Aeronaves)
// ─────────────────────────────────────────────────────────────────────────────
// Conjunto de enums para preferências de aeronaves:
// uso principal, foco, faixa de valor, capacidade, autonomia, etc.

enum UsoPrincipalAircraftInterest {
