enum ExperienciaNavegacao {
  NENHUMA       @map("nenhuma")
  BASICA        @map("basica")
  MEDIO_PORTE   @map("medio_porte")
  IATES_GRANDES @map("iates_grandes")
}

enum OperacaoEmbarcacao {
  PESSOAL     @map("pessoal")
  COM_AUXILIO @map("com_auxilio")
  APENAS_CREW @map("apenas_crew_capitao")
