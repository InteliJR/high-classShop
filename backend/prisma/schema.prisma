}

enum PrazoAquisicaoAircraft {
  IMEDIATO @map("imediato")
  CURTO    @map("curto")
  MEDIO    @map("medio")
  LONGO    @map("longo")
}

// ─────────────────────────────────────────────────────────────────────────────
// ▸ ENUMS LEGADOS (Não utilizados atualmente)
// ─────────────────────────────────────────────────────────────────────────────
// Especialidade: especializações para veículos, embarcações e aeronaves

// === Legacy/Unused Enum ===
enum Especialidade {
  CARROS    @map("carros")
  BARCOS    @map("barcos")
  AERONAVES @map("aeronaves")
}

// ═══════════════════════════════════════════════════════════════════════════
// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║                         MODELOS / MODELS                                  ║
// ║   (Auth → Core → Produtos → Processos → Agendamentos → Interesses)        ║
// ╚═══════════════════════════════════════════════════════════════════════════╝
// ═══════════════════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────────────────────
// ▸ AUTH & USUÁRIOS
// ─────────────────────────────────────────────────────────────────────────────
// User: representa usuários do sistema
// Relações: Address, Company, Process, Contract, RefreshToken, Appointment, Interests

model User {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  surname       String
  email         String   @unique
  cpf           String   @unique @db.VarChar(11)
  rg            String   @unique @db.VarChar(10)
  role          UserRole
  password_hash String

  civil_state           CivilState?
  speciality            ProductType?
  identification_number String?      @unique @db.VarChar(50)

  address_id    String? @db.Uuid
  consultant_id String? @db.Uuid
  company_id    String? @db.Uuid

  address    Address? @relation(fields: [address_id], references: [id])
  consultant User?    @relation("ClientToConsultant", fields: [consultant_id], references: [id], onDelete: SetNull)
  clients    User[]   @relation("ClientToConsultant")
  company    Company? @relation(fields: [company_id], references: [id])

  // Campo para integração com Calendly - especialistas armazenam seu link de agendamento
  // Ex: https://calendly.com/nome-especialista
  calendly_url String?

  created_at               DateTime            @default(now())
  updated_at               DateTime            @updatedAt
  cars                     Car[]
  boats                    Boat[]
  aircraft                 Aircraft[]
  processesAsClient        Process[]           @relation("process_as_client")
  processesAsSpecialist    Process[]           @relation("process_as_specialist")
  appointmentsAsClient     Appointment[]       @relation("appointment_as_client")
  appointmentsAsSpecialist Appointment[]       @relation("appointment_as_specialist")
  car_interests            Car_interest[]
  boat_interests           Boat_interest[]
  aircraft_interests       Aircraft_interest[]
  refreshTokens            RefreshToken[]
  created_contracts        Contract[]          @relation("contract_created_by")
  signed_contracts         Contract[]          @relation("contract_signed_by")
  process_rejections       ProcessRejection[]
}

// RefreshToken: tokens de sessão vinculados a usuários
model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  token      String   @unique
  user_id    String   @db.Uuid
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([user_id])
  @@index([token])
}

// ─────────────────────────────────────────────────────────────────────────────
// ▸ ENTIDADES CORE
// ─────────────────────────────────────────────────────────────────────────────
// Address: endereços vinculados aos usuários
// Company: empresas / consultorias que empregam consultores

// === Core Entities ===
model Address {
  id           String @id @default(uuid()) @db.Uuid
  street       String
  number       String
  neighborhood String
  city         String
  state        String
  cep          String
  country      String

  users User[]
}

// Company: organizações que empregam consultores
model Company {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  cnpj        String   @unique
  logo        String?
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  consultants User[]
}

// ─────────────────────────────────────────────────────────────────────────────
// ▸ PRODUTOS & IMAGENS
// ─────────────────────────────────────────────────────────────────────────────
// Car / Boat / Aircraft: inventário de veículos, embarcações e aeronaves de luxo
// [Type]_image: imagens específicas por tipo de produto
// Nota: ids Int com TODO para futura migração a UUID

// === Products & Images ===
// Car: inventário de automóveis de luxo
// TODO: converter id Int para UUID em migração futura
model Car {
  id             Int      @id @default(autoincrement())
  specialist_id  String?  @db.Uuid
  marca          String
  modelo         String
  valor          Decimal
  estado         String
  ano            Int
  descricao      String?
  cor            String?
  km             Int?
  cambio         String?
  combustivel    String?
  tipo_categoria String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  specialist User?       @relation(fields: [specialist_id], references: [id])
  images     Car_image[]
  processes  Process[]

  @@index([specialist_id])
}

// Car_image: imagens associadas aos anúncios de Car
model Car_image {
  id           Int      @id @default(autoincrement())
  product_type String
  image_url    String
  is_primary   Boolean  @default(false)
  created_at   DateTime @default(now())

  car_id Int?
  car    Car? @relation(fields: [car_id], references: [id])

  @@index([car_id])
}

// Boat: inventário de iates/embarcações de luxo
// TODO: converter id Int para UUID em migração futura
model Boat {
  id                 Int      @id @default(autoincrement())
  specialist_id      String?  @db.Uuid
  marca              String
  modelo             String
  valor              Decimal
  ano                Int
  fabricante         String?
  tamanho            String?
  estilo             String?
  combustivel        String?
  motor              String?
  ano_motor          Int?
  descricao_completa String?
  acessorios         String?
  estado             String
  tipo_embarcacao    String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  specialist User?        @relation(fields: [specialist_id], references: [id])
  images     Boat_image[]
  processes  Process[]

  @@index([specialist_id])
}

// Boat_image: imagens associadas aos anúncios de Boat
model Boat_image {
  id           Int      @id @default(autoincrement())
  product_type String
  image_url    String
  is_primary   Boolean  @default(false)
  created_at   DateTime @default(now())

  boat_id Int?
  boat    Boat? @relation(fields: [boat_id], references: [id])

  @@index([boat_id])
}

// Aircraft: inventário de aeronaves de luxo
// TODO: converter id Int para UUID em migração futura
model Aircraft {
  id            Int      @id @default(autoincrement())
  specialist_id String?  @db.Uuid
  categoria     String?
  ano           Int
  marca         String
  modelo        String
  assentos      Int?
  estado        String
  descricao     String?
  valor         Decimal
  tipo_aeronave String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  specialist User?            @relation(fields: [specialist_id], references: [id])
  images     Aircraft_image[]
  processes  Process[]

  @@index([specialist_id])
}

// Aircraft_image: imagens associadas aos anúncios de Aircraft
model Aircraft_image {
  id           Int      @id @default(autoincrement())
  product_type String
  image_url    String
  is_primary   Boolean  @default(false)
  created_at   DateTime @default(now())

  aircraft_id Int?
  aircraft    Aircraft? @relation(fields: [aircraft_id], references: [id])

  @@index([aircraft_id])
}

// Product: camada de abstração para entidades de produto (Car, Boat, Aircraft)
// TODO: converter car_id, boat_id, aircraft_id para UUID quando IDs de produto migrarem
model Product {
  id          String      @id @default(uuid()) @db.Uuid
  type        ProductType
  car_id      Int?
  boat_id     Int?
  aircraft_id Int?

  process   Process? @relation(fields: [processId], references: [id])
  processId String?  @db.Uuid

  @@index([processId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ▸ PROCESSOS & CONTRATOS
// ─────────────────────────────────────────────────────────────────────────────
// Process: fluxo de negociação entre cliente, especialista e produto
// ProcessStatusHistory: histórico de alterações de status
// Contract: documentos digitais com integração a provedores de assinatura

// === Processes & Contracts ===
// Process: fluxo de negociação/venda vinculando cliente, especialista e produto
// TODO: converter car_id, boat_id, aircraft_id para UUID em migração futura
model Process {
  id            String @id @default(uuid()) @db.Uuid
  client_id     String @db.Uuid
  specialist_id String @db.Uuid
  car_id        Int?
  aircraft_id   Int?
  boat_id       Int?

  product_id         String?       @db.Uuid
  product_type       ProductType
  active_contract_id String?       @unique @db.Uuid
  status             ProcessStatus @default(SCHEDULING)
  notes              String?
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt

  car      Car?      @relation(fields: [car_id], references: [id])
  boat     Boat?     @relation(fields: [boat_id], references: [id])
  aircraft Aircraft? @relation(fields: [aircraft_id], references: [id])

  client     User @relation("process_as_client", fields: [client_id], references: [id], map: "fk_process_as_client")
  specialist User @relation("process_as_specialist", fields: [specialist_id], references: [id], map: "fk_process_as_specialist")

  active_contract Contract?  @relation("process_active_contract", fields: [active_contract_id], references: [id])
  contracts       Contract[] @relation("process_contracts")

  ProcessStatusHistory ProcessStatusHistory[]
  rejections           ProcessRejection[]
  products             Product[]
  // Rastreabilidade: referência ao Appointment que originou este Process (Calendly integration)
  // onDelete Cascade: se Appointment for deletado, Process também é deletado para manter integridade
  appointment          Appointment?           @relation("appointment_process", fields: [appointment_id], references: [id], onDelete: Cascade)
  appointment_id       String?                @unique @db.Uuid

  @@unique([client_id, specialist_id, car_id, boat_id, aircraft_id], name: "unique_active_product")
  @@index([status])
  @@index([product_type])
  @@index([product_id])
  @@index([created_at])
}

// ProcessStatusHistory: trilha de auditoria para alterações de status do processo
model ProcessStatusHistory {
  id         String                   @id @default(uuid())
  process    Process                  @relation(fields: [processId], references: [id])
  processId  String                   @db.Uuid
  status     ProcessStatus            @default(SCHEDULING)
  reason     ProcessCompletionReason?
  changed_by String?                  @db.Uuid
  changed_at DateTime                 @default(now())

  @@index([processId])
  @@index([changed_at])
}

// ProcessRejection: registro de rejeição de um processo com motivo textual
model ProcessRejection {
  id               String   @id @default(uuid()) @db.Uuid
  process_id       String   @db.Uuid
  rejected_by_id   String   @db.Uuid
  rejection_reason String   @db.Text
  rejected_at      DateTime @default(now())

  process     Process @relation(fields: [process_id], references: [id], onDelete: Cascade)
  rejected_by User    @relation(fields: [rejected_by_id], references: [id])

  @@index([process_id])
  @@index([rejected_by_id])
  @@index([rejected_at])
}

// Contract: documentos digitais com integração a provedores de assinatura (DocuSign, etc.)
model Contract {
  id          String  @id @default(uuid()) @db.Uuid
  process_id  String  @db.Uuid
  description String?

  provider_name   String?
  provider_id     String?
  provider_status ProviderStatus?
  provider_meta   Json?

  file_name        String
  file_path        String
  file_type        String
  file_size        Int
  original_pdf_url String

  status          ContractStatus @default(PENDING)
  rejected_reason String?
  signed_at       DateTime?
  signature_type  SignatureType?

  active_of_process Process? @relation("process_active_contract")
  process           Process  @relation("process_contracts", fields: [process_id], references: [id])

  uploaded_by_id   String   @db.Uuid
  uploaded_by_type UserRole
  uploaded_by      User     @relation("contract_created_by", fields: [uploaded_by_id], references: [id])

  signed_by_id String? @db.Uuid
  signed_by    User?   @relation("contract_signed_by", fields: [signed_by_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([process_id])
  @@index([uploaded_by_id])
  @@index([provider_status])
}

// ─────────────────────────────────────────────────────────────────────────────
// ▸ AGENDAMENTOS
// ─────────────────────────────────────────────────────────────────────────────
// Appointment: reuniões agendadas entre cliente e especialista
// Para Calendly: cliente acessa link do especialista externamente, retorna à plataforma
// e confirma o agendamento. Sistema cria automaticamente Process em status SCHEDULING.

// === Appointments ===
// Appointment: reuniões agendadas entre cliente e especialista
// Estrutura simplificada para Calendly: cliente agenda via link externo, confirma no sistema
// - id: UUID para consistência com resto do sistema
// - appointment_datetime: ISO 8601 em UTC. Frontend converte para horário local do usuário
// - status: StatusAgendamento enum (SCHEDULED, COMPLETED, CANCELLED)
// - product_type: tipo do produto (car, boat, aircraft) - obrigatório
// - product_id: identificador do produto (car_id, boat_id ou aircraft_id) - obrigatório
// - notes: anotações opcionais sobre o agendamento
model Appointment {
  id            String      @id @default(uuid()) @db.Uuid
  client_id     String      @db.Uuid
  specialist_id String      @db.Uuid
  product_type  ProductType // CAR, BOAT ou AIRCRAFT
  product_id    Int // id do Car, Boat ou Aircraft específico

  // Data e hora do agendamento em UTC (ISO 8601)
  // Exemplo: "2024-10-10T14:00:00Z"
  // Frontend: converte para horário local do usuário ao exibir
  appointment_datetime DateTime

  // Status do agendamento
  status StatusAgendamento @default(SCHEDULED)

  // Anotações sobre o agendamento (ex: "Test drive do Ferrari F8")
  notes String?

  // Rastreabilidade e auditoria
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relacionamentos
  client     User @relation("appointment_as_client", fields: [client_id], references: [id], map: "fk_appointment_as_client")
  specialist User @relation("appointment_as_specialist", fields: [specialist_id], references: [id], map: "fk_appointment_as_specialist")

  // Process vinculado a este agendamento (criado automaticamente ao confirmar)
  // Uma-para-um: cada Appointment está associado a um Process
  process Process? @relation("appointment_process")

  @@index([client_id])
  @@index([specialist_id])
  @@index([appointment_datetime])
  @@index([status])
  @@index([product_type])
}

// ─────────────────────────────────────────────────────────────────────────────
// ▸ INTERESSES (Preferências dos clientes)
// ─────────────────────────────────────────────────────────────────────────────
// Car_interest / Boat_interest / Aircraft_interest: critérios e preferências de busca

// === Interests (Client Preferences) ===
// Car_interest: preferências de cliente e critérios de busca para veículos
model Car_interest {
  id                      Int      @id @default(autoincrement())
  client_id               String?  @db.Uuid
  uso_principal           String?
  preferencia_foco        String?
  faixa_valor             String?
  status                  String?
  marca_preferida         String?
  modelo_preferido        String?
  perfil_veiculo          String?
  blindagem               Boolean?
  carroceria              String?
  fator_importante        String?
  recursos_indispensaveis String?
  estilo_viagem           String?
  mensagem_imagem         String?
  prazo_aquisicao         String?
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  client User? @relation(fields: [client_id], references: [id])

  @@index([client_id])
}

