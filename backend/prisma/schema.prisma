// Schema Prisma do high-classShop: plataforma de marketplace para veículos, embarcações e aeronaves de luxo
// Documentação: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════
// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║                        ENUMERAÇÕES / ENUMS                                ║
// ║              (NÚCLEO → PRODUTO → PROCESSOS → AGENDAMENTOS → INTERESSES)   ║
// ╚═══════════════════════════════════════════════════════════════════════════╝
// ═══════════════════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────────────────────
// ▸ NÚCLEO (Core)
// ─────────────────────────────────────────────────────────────────────────────
// • CivilState: estado civil do usuário
// • UserRole: papéis de autorização e propriedade de recursos
// • ProductType: categorias principais de produto
// • ProcessStatus: etapas do fluxo de processo de venda
// • ContractStatus: status legal do contrato
// • SignatureType: tipos de assinatura digital
// • ProviderStatus: estados do envelope do provedor de assinatura
// • ProcessCompletionReason: motivo de conclusão do processo

// === Core Enums ===
// CivilState: estado civil do usuário
enum CivilState {
  SINGLE       @map("SINGLE")
  MARRIED      @map("MARRIED")
  DIVORCED     @map("DIVORCED")
  WIDOWED      @map("WIDOWED")
  SEPARATED    @map("SEPARATED")
  STABLE_UNION @map("STABLE_UNION")
}

// UserRole: papéis de autorização e propriedade de recursos
enum UserRole {
  CUSTOMER   @map("CUSTOMER")
  CONSULTANT @map("CONSULTANT")
  SPECIALIST @map("SPECIALIST")
  ADMIN      @map("ADMIN")
}

// ProductType: categorias principais de produto
enum ProductType {
  CAR      @map("CAR")
  BOAT     @map("BOAT")
  AIRCRAFT @map("AIRCRAFT")
}

// ProcessStatus: etapas do fluxo de processos de venda
enum ProcessStatus {
  SCHEDULING          @map("SCHEDULING")
  NEGOTIATION         @map("NEGOTIATION")
  PROCESSING_CONTRACT @map("PROCESSING_CONTRACT")
  DOCUMENTATION       @map("DOCUMENTATION")
  COMPLETED           @map("COMPLETED")
  REJECTED            @map("REJECTED")
}

// ContractStatus: status de documento legal
enum ContractStatus {
  PENDING  @map("PENDING")
  REJECTED @map("REJECTED")
  SIGNED   @map("SIGNED")
}

// SignatureType: métodos de assinatura digital (Simples, Avançada, Qualificada)
enum SignatureType {
  SIMPLE
  ADVANCED
  QUALIFIED
}

// ProviderStatus: estados do envelope do provedor de assinatura (DocuSign, etc.)
enum ProviderStatus {
  CREATED   @map("created")
  SENT      @map("sent")
  DELIVERED @map("delivered")
  COMPLETED @map("completed")
  DECLINED  @map("declined")
  VOIDED    @map("voided")
  TIMEDOUT  @map("timeout")
  ERROR     @map("error")
}

// ProcessCompletionReason: motivo pelo qual um processo foi concluído
enum ProcessCompletionReason {
  CONTRACT_SIGNED   @map("CONTRACT_SIGNED")
  CLIENT_DECLINED   @map("CLIENT_DECLINED")
  CONTRACT_VOIDED   @map("CONTRACT_VOIDED")
  CONTRACT_TIMEDOUT @map("CONTRACT_TIMEDOUT")
}

// ─────────────────────────────────────────────────────────────────────────────
// ▸ PRODUTO (Product Enums)
// ─────────────────────────────────────────────────────────────────────────────
// • EstadoProduto: condição do produto
// • TipoCategoriaCarro: categorias de automóvel
// • TipoEmbarcacaoProduto: tipos de embarcação
// • TipoAeronaveProduto: categorias de aeronave

// === Product Enums ===
// EstadoProduto: condição do produto (novo, seminovo, coleção)
enum EstadoProduto {
  NOVO     @map("novo")
  SEMINOVO @map("seminovo")
  COLECAO  @map("colecao")
}

// TipoCategoriaCarro: categorias de automóvel
enum TipoCategoriaCarro {
  SUV         @map("SUV")
  SEDAN       @map("sedan")
  COUPE       @map("coupe")
  CONVERSIVEL @map("conversivel")
  ESPORTIVO   @map("esportivo")
  SUPERCARRO  @map("supercarro")
}

// TipoEmbarcacaoProduto: tipos de embarcação
enum TipoEmbarcacaoProduto {
  IATE     @map("iate")
  LANCHA   @map("lancha")
  CATAMARA @map("catamara")
  VELEIRO  @map("veleiro")
  JET_BOAT @map("jet_boat")
  OUTRO    @map("outro")
}

// TipoAeronaveProduto: categorias de aeronave
enum TipoAeronaveProduto {
  VLJ              @map("VLJ")
  EXECUTIVO_MEDIO  @map("executivo_medio")
  INTERCONTINENTAL @map("intercontinental")
  TURBOHELICE      @map("turbohelice")
  HELICOPTERO      @map("helicoptero")
}

// ─────────────────────────────────────────────────────────────────────────────
// ▸ PROCESSOS & AGENDAMENTOS
// ─────────────────────────────────────────────────────────────────────────────
// • TipoProdutoProcesso: tipo de produto em processos
// • TipoProdutoAgendamento: tipo de produto em agendamentos
// • StatusAgendamento: ciclo de vida do agendamento

// === Process & Schedule Enums ===
// TipoProdutoProcesso: tipo de produto para rastreamento de processos
enum TipoProdutoProcesso {
  CAR      @map("car")
  BOAT     @map("boat")
  AIRCRAFT @map("aircraft")
}

// TipoProdutoAgendamento: tipo de produto para agendamentos
enum TipoProdutoAgendamento {
  CAR      @map("car")
  BOAT     @map("boat")
  AIRCRAFT @map("aircraft")
}

// StatusAgendamento: ciclo de vida do agendamento
enum StatusAgendamento {
  SCHEDULED @map("scheduled")
  COMPLETED @map("completed")
  CANCELLED @map("cancelled")
}

// ─────────────────────────────────────────────────────────────────────────────
// ▸ INTERESSES (Preferências de Barcos)
// ─────────────────────────────────────────────────────────────────────────────
// Conjunto de enums para preferências de embarcações:
// uso principal, foco, faixa de valor, status, tipo, tamanho, etc.

enum UsoPrincipalBoatInterest {
  LAZER                @map("lazer")
  CRUZEIROS            @map("cruzeiros")
  PESCA                @map("pesca")
  EVENTOS              @map("eventos")
  COLECAO_INVESTIMENTO @map("colecao_investimento")
}

enum PreferenciaFocoBoatInterest {
  CONFORTO    @map("conforto")
  PERFORMANCE @map("performance")
  EQUILIBRIO  @map("equilibrio")
}

enum FaixaValorBoatInterest {
  ATE_500K   @map("ate_500k")
  DE_500K_1M @map("500k_1M")
  ACIMA_1M   @map("acima_1M")
}

enum StatusBoatInterest {
  NOVA             @map("nova")
  SEMINOVA         @map("seminova")
  COLECAO_RARIDADE @map("colecao_raridade")
}

enum TipoEmbarcacaoBoatInterest {
  IATE     @map("iate")
  LANCHA   @map("lancha")
  CATAMARA @map("catamara")
  VELEIRO  @map("veleiro")
  JET_BOAT @map("jet_boat")
  OUTRO    @map("outro")
}

enum TamanhoEmbarcacao {
  ATE_30_PES   @map("ate_30_pes")
  DE_30_50_PES @map("30_50_pes")
  ACIMA_50_PES @map("acima_50_pes")
}

enum MotorBoatInterest {
  DIESEL           @map("diesel")
  GASOLINA         @map("gasolina")
  ELETRICO_HIBRIDO @map("eletrico_hibrido")
}

enum CapacidadePessoasBoat {
  DE_1_4 @map("1_4")
  DE_5_8 @map("5_8")
  MAIS_8 @map("mais_8")
}

enum CabinePernoiteBoat {
  DAY_BOAT  @map("day_boat")
  UMA_DUAS  @map("1_2_cabines")
  MAIS_DUAS @map("mais_2_cabines")
}

enum ExperienciaNavegacao {
  NENHUMA       @map("nenhuma")
  BASICA        @map("basica")
  MEDIO_PORTE   @map("medio_porte")
  IATES_GRANDES @map("iates_grandes")
}

enum OperacaoEmbarcacao {
  PESSOAL     @map("pessoal")
  COM_AUXILIO @map("com_auxilio")
  APENAS_CREW @map("apenas_crew_capitao")
}

enum MarinaPreferencia {
  POSSUI            @map("possui")
  PRECISA_INDICACAO @map("precisa_indicacao")
  NAO_PRIORIDADE    @map("nao_prioridade")
}

enum PrazoAquisicaoBoat {
  IMEDIATO @map("imediato")
  CURTO    @map("curto")
  MEDIO    @map("medio")
  LONGO    @map("longo")
