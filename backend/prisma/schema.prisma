// ─────────────────────────────────────────────────────────────────────────────
// ▸ INTERESSES (Preferências de Aeronaves)
// ─────────────────────────────────────────────────────────────────────────────
// Conjunto de enums para preferências de aeronaves:
// uso principal, foco, faixa de valor, capacidade, autonomia, etc.

enum UsoPrincipalAircraftInterest {
  CORPORATIVO          @map("corporativo")
  LAZER                @map("lazer")
  TURISMO              @map("turismo")
  TRANSPORTE_FAMILIA   @map("transporte_familia")
  COLECAO_INVESTIMENTO @map("colecao_investimento")
}

enum PreferenciaFocoAircraft {
  CONFORTO_LUXO @map("conforto_luxo")
  PERFORMANCE   @map("performance")
  EQUILIBRIO    @map("equilibrio")
}

enum FaixaValorAircraft {
  ATE_5M    @map("ate_5M")
  DE_5_20M  @map("5_20M")
  ACIMA_20M @map("acima_20M")
}

enum StatusAircraft {
  NOVA             @map("nova")
  SEMINOVA         @map("seminova")
  COLECAO_RARIDADE @map("colecao_raridade")
}

enum TipoAeronaveAircraft {
  VLJ              @map("VLJ")
  EXECUTIVO        @map("executivo")
  INTERCONTINENTAL @map("intercontinental")
  TURBOHELICE      @map("turbohelice")
  HELICOPTERO      @map("helicoptero")
  OUTRO            @map("outro")
}

enum AlcanceAutonomia {
  CURTA @map("curta")
  MEDIA @map("media")
  LONGA @map("longa")
}

enum CapacidadePassageiros {
  ATE_4  @map("ate_4")
  DE_5_8 @map("5_8")
  MAIS_8 @map("mais_8")
}

enum ExperienciaVoo {
  NENHUMA                   @map("nenhuma")
  AERONAVES_LEVES           @map("aeronaves_leves")
  EXECUTIVOS_TURBOHELICES   @map("executivos_turbohelices")
  GRANDES_INTERCONTINENTAIS @map("grandes_intercontinentais")
}

enum OperacaoAeronave {
  PILOTAR_PESSOALMENTE @map("pilotar_pessoalmente")
  COM_AUXILIO          @map("com_auxilio")
  APENAS_CREW_PILOTO   @map("apenas_crew_piloto")
