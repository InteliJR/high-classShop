# Database
DATABASE_URL="postgresql://user:password@localhost:5432/highclassdb?schema=public"

# AWS Configuration (for S3 and SES)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_BUCKET_NAME=your-bucket-name

# Email Configuration (Amazon SES)
EMAIL_FROM=noreply@highclass.com

# Frontend URL (for registration links)
FRONTEND_URL=http://localhost:5173

# JWT Configuration (for referral tokens)
JWT_SECRET=jwt-example-secret-key

