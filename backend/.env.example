# ===== APLICAÇÃO =====
NODE_ENV=production  # 'development' | 'production'
PORT=3000
LOG_LEVEL=info       # 'debug' | 'info' | 'warn' | 'error'

# ===== BANCO DE DADOS =====
# URL de conexão do PostgreSQL
DATABASE_URL="postgresql://user:password@db:5432/highclassdb?schema=public"
# URL direta sem pooler (recomendada para migrations/Prisma CLI)
DIRECT_URL="postgresql://user:password@db:5432/highclassdb?schema=public"

# ===== FRONTEND =====
# URL do frontend para CORS e links de email
FRONTEND_URL=http://localhost:5173

# ===== AWS CONFIGURATION =====
# Credenciais AWS para S3 e SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_BUCKET_NAME=highclass-shop-bucket

# ===== EMAIL (AWS SES) =====
# Email remetente verificado no AWS SES
EMAIL_FROM=noreply@highclass.com

# ===== JWT SECRETS =====
# Chaves secretas para JWT (usar valores diferentes em produção)
JWT_SECRET_ACCESS=your-super-secret-jwt-access-key-change-this-in-production
JWT_SECRET_REFRESH=your-super-secret-jwt-refresh-key-change-this-in-production
JWT_SECRET_REFERRAL=your-super-secret-jwt-referral-key-change-this-in-production
JWT_SECRET_ADVISOR=your-super-secret-jwt-advisor-key-change-this-in-production
JWT_SECRET_PASSWORD_RESET=your-super-secret-jwt-password-reset-key-change-this-in-production

# ===== DOCUSIGN INTEGRATION =====
# Credenciais do DocuSign para assinatura de contratos
DOCUSIGN_INTEGRATION_KEY=integration-key-from-docusign-dashboard
DOCUSIGN_USER_ID=user-id-from-docusign
DOCUSIGN_ACCOUNT_ID=account-id-from-docusign
DOCUSIGN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
DOCUSIGN_ENV=demo  # 'demo' para sandbox | 'prod' para produção
DOCUSIGN_TEMPLATE_ID=

# Webhook secret para validar callbacks do DocuSign
DOCUSIGN_WEBHOOK_SECRET=webhook-secret-for-signature-validation

# URL base do backend para webhooks (usado pelo DocuSign para callbacks)
BACKEND_URL=http://localhost:3000

# ===== CALENDLY INTEGRATION =====
# Token de acesso do Calendly para agendamentos (opcional)
CALENDLY_ACCESS_TOKEN=your-calendly-access-token

# ===== GOOGLE DRIVE IMPORT =====
# Chave de API para listar/baixar imagens de pasta pública do Google Drive
GOOGLE_DRIVE_API_KEY=your-google-drive-api-key

# ===== GOOGLE MEET INTEGRATION (OAuth2 conectável via painel admin) =====
# O admin conecta UMA conta Google Workspace pelo painel (/admin/settings). O refresh token
# fica criptografado no banco. As reuniões são criadas via Meet REST API (spaces.create) com
# accessType=OPEN, garantindo que cliente externo/anônimo entre sem sala de espera.
# Pré-condição: a conta conectada precisa ser Google Workspace (conta @gmail.com comum não cria Meet via API).
# App OAuth criado no Google Cloud Console (Meet API habilitada). Scopes: meetings.space.created + meetings.space.settings + openid + email.
GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/meetings/google/oauth/callback
# Chave AES-256-GCM (32 bytes UTF-8 ou base64 de 32 bytes) para criptografar os tokens
GOOGLE_MEET_TOKEN_ENCRYPTION_KEY=change-me-32-bytes-key-rotate-prod
# OPEN (recomendado: sem sala de espera) | TRUSTED | RESTRICTED
GOOGLE_MEET_ACCESS_TYPE=OPEN
MEETING_DEMO_FALLBACK_ENABLED=false
MEETING_PROVIDER=GOOGLE
JITSI_BASE_URL=https://meet.jit.si

# ========= MOCK INFORMATION
MOCK_PASSWORD_HASH=

# Forçar limpeza de processos
FORCE_CLEAR=true
